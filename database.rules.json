{
  "rules": {
    "att_users": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.hasChildren(['name'])"
      }
    },

    "attendance": {
      ".read": "auth != null",
      "master": {
        ".write": "auth != null"
      },
      "months": {
        ".indexOn": ["uploaded_at"],
        "$ym": {
          ".write": "auth != null"
        }
      }
    }
  }
}
